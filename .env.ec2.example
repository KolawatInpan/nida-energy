# Copy this file to .env.ec2 before deploy and adjust values for your EC2 machine.

POSTGRES_DB=energy_trading
POSTGRES_DB_DEMO=energy_trading_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

FRONTEND_PORT=80
BLOCKCHAIN_PORT=8545

FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
SECRET_KEY=change-this-to-a-long-random-secret
DEFAULT_DATA_MODE=real

RUN_PRISMA_DB_PUSH=true
RUN_PRISMA_MIGRATE=false

ETH_RPC_URL=http://blockchain:8545
ETH_PRIVATE_KEY=
ETH_CHAIN_ID=31337
ETH_EXPLORER_BASE_URL=
ETH_VERIFICATION_CONTRACT_ADDRESS=

REACT_APP_MOCKUPMODE=false
