generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  BATTERY
  PRODUCER
  CONSUMER
  ADMIN
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum EnergyOfferStatus {
  AVAILABLE
  BOUGHT
  CANCELLED
}

//////////////////////////////////////////////////////
// USER / AUTH
//////////////////////////////////////////////////////

model User {
  credId        String   @db.Uuid @unique
  name          String
  email         String   @id @unique
  passwordHash  String
  address       String?
  telNum        String?
  lineID        String?
  position      String?
  role          UserRole @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credentials   UserCredential[]
  buildings     Building[]
  wallets       Wallet[]
}

model UserCredential {
  credId     String   @db.Uuid
  type       String
  identifier String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [credId], references: [credId])

  @@id([credId, type])
}

//////////////////////////////////////////////////////
// BUILDING / METER
//////////////////////////////////////////////////////

model Building {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  mapURL    String?
  address   String?
  province  String?
  postal    String?
  status    String?
  energy    Decimal? @db.Decimal(12, 4)
  email     String

  produceSN String?
  consumeSN String?
  batSN     String?

  createdAt DateTime @default(now())

  owner User @relation(fields: [email], references: [email])
  meters MeterInfo[]
  transactions Transaction[]
}

model MeterInfo {
  snid           String   @unique
  requestId     String?
  buildingName  String
  meterName     String   @unique
  value         Decimal? @db.Decimal(12, 4)
  capacity      Decimal? @db.Decimal(12, 4)
  timestamp     DateTime?
  type String
  dateInstalled DateTime?
  dateSubmit    DateTime?
  approveStatus String
  
  kWH           Decimal? @db.Decimal(12, 4)

  building Building @relation(fields: [buildingName], references: [name])
  hourlyEnergy  HourlyEnergy[]
  dailyEnergy   DailyEnergy[]
  weeklyEnergy  WeeklyEnergy[]
  monthlyEnergy MonthlyEnergy[]
  runningMeter RunningMeter[]
}

//////////////////////////////////////////////////////
// ENERGY AGGREGATION
//////////////////////////////////////////////////////

model RunningMeter {
  id        String   @id @default(uuid())
  snid      String
  txid      String?
  timestamp DateTime
  kW        Decimal? @db.Decimal(12, 4)
  kWH       Decimal? @db.Decimal(12, 4)

  meter MeterInfo @relation(fields: [snid], references: [snid])

  @@index([snid])
  @@index([snid, timestamp])
  @@unique([snid, timestamp])
}

model HourlyEnergy {
  meterId String
  date      DateTime @db.Date

  h0  Decimal? @db.Decimal(12, 4)
  h1  Decimal? @db.Decimal(12, 4)
  h2  Decimal? @db.Decimal(12, 4)
  h3  Decimal? @db.Decimal(12, 4)
  h4  Decimal? @db.Decimal(12, 4)
  h5  Decimal? @db.Decimal(12, 4)
  h6  Decimal? @db.Decimal(12, 4)
  h7  Decimal? @db.Decimal(12, 4)
  h8  Decimal? @db.Decimal(12, 4)
  h9  Decimal? @db.Decimal(12, 4)
  h10 Decimal? @db.Decimal(12, 4)
  h11 Decimal? @db.Decimal(12, 4)
  h12 Decimal? @db.Decimal(12, 4)
  h13 Decimal? @db.Decimal(12, 4)
  h14 Decimal? @db.Decimal(12, 4)
  h15 Decimal? @db.Decimal(12, 4)
  h16 Decimal? @db.Decimal(12, 4)
  h17 Decimal? @db.Decimal(12, 4)
  h18 Decimal? @db.Decimal(12, 4)
  h19 Decimal? @db.Decimal(12, 4)
  h20 Decimal? @db.Decimal(12, 4)
  h21 Decimal? @db.Decimal(12, 4)
  h22 Decimal? @db.Decimal(12, 4)
  h23 Decimal? @db.Decimal(12, 4)

  kWH Decimal @default(0) @db.Decimal(12, 4)

  meter MeterInfo @relation(fields: [meterId], references: [snid])

  @@id([meterId, date])
}

model DailyEnergy {
  meterId String
  year Int
  month Int

  d1  Decimal? @db.Decimal(12, 4)
  d2  Decimal? @db.Decimal(12, 4)
  d3  Decimal? @db.Decimal(12, 4)
  d4  Decimal? @db.Decimal(12, 4)
  d5  Decimal? @db.Decimal(12, 4)
  d6  Decimal? @db.Decimal(12, 4)
  d7  Decimal? @db.Decimal(12, 4)
  d8  Decimal? @db.Decimal(12, 4)
  d9  Decimal? @db.Decimal(12, 4)
  d10 Decimal? @db.Decimal(12, 4)
  d11 Decimal? @db.Decimal(12, 4)
  d12 Decimal? @db.Decimal(12, 4)
  d13 Decimal? @db.Decimal(12, 4)
  d14 Decimal? @db.Decimal(12, 4)
  d15 Decimal? @db.Decimal(12, 4)
  d16 Decimal? @db.Decimal(12, 4)
  d17 Decimal? @db.Decimal(12, 4)
  d18 Decimal? @db.Decimal(12, 4)
  d19 Decimal? @db.Decimal(12, 4)
  d20 Decimal? @db.Decimal(12, 4)
  d21 Decimal? @db.Decimal(12, 4)
  d22 Decimal? @db.Decimal(12, 4)
  d23 Decimal? @db.Decimal(12, 4)
  d24 Decimal? @db.Decimal(12, 4)
  d25 Decimal? @db.Decimal(12, 4)
  d26 Decimal? @db.Decimal(12, 4)
  d27 Decimal? @db.Decimal(12, 4)
  d28 Decimal? @db.Decimal(12, 4)
  d29 Decimal? @db.Decimal(12, 4)
  d30 Decimal? @db.Decimal(12, 4)
  d31 Decimal? @db.Decimal(12, 4)

  kWH Decimal @default(0) @db.Decimal(12, 4)

  meter MeterInfo @relation(fields: [meterId], references: [snid])

  @@id([meterId, year, month])
}

model WeeklyEnergy {
  meterId String
  year Int
  week Int

  sun Decimal? @db.Decimal(12, 4)
  mon Decimal? @db.Decimal(12, 4)
  tue Decimal? @db.Decimal(12, 4)
  wed Decimal? @db.Decimal(12, 4)
  thu Decimal? @db.Decimal(12, 4)
  fri Decimal? @db.Decimal(12, 4)
  sat Decimal? @db.Decimal(12, 4)

  kWH Decimal @default(0) @db.Decimal(12, 4)

  meter MeterInfo @relation(fields: [meterId], references: [snid])

  @@id([meterId, year, week])
}

model MonthlyEnergy {
  meterId String
  year      Int

  M1  Decimal? @db.Decimal(12, 4)
  M2  Decimal? @db.Decimal(12, 4)
  M3  Decimal? @db.Decimal(12, 4)
  M4  Decimal? @db.Decimal(12, 4)
  M5  Decimal? @db.Decimal(12, 4)
  M6  Decimal? @db.Decimal(12, 4)
  M7  Decimal? @db.Decimal(12, 4)
  M8  Decimal? @db.Decimal(12, 4)
  M9  Decimal? @db.Decimal(12, 4)
  M10 Decimal? @db.Decimal(12, 4)
  M11 Decimal? @db.Decimal(12, 4)
  M12 Decimal? @db.Decimal(12, 4)

  kWH Decimal @default(0) @db.Decimal(12, 4)

  meter MeterInfo @relation(fields: [meterId], references: [snid])

  @@id([meterId, year])
}

//////////////////////////////////////////////////////
// WALLET / TRANSACTION
//////////////////////////////////////////////////////

model Wallet {
  id           String   @id
  email        String
  encryptedKey String?
  isCustodial  Boolean  @default(false)
  chain        String   @default("ganache")
  tokenBalance Float    @default(0)
  quota        Float?

  user         User @relation(fields: [email], references: [email])
  txs          WalletTx[]
  transactions Transaction[]
}

model WalletTx {
  id         String   @id
  walletId   String
  timestamp  DateTime @default(now())
  tokenInOut Float

  wallet Wallet @relation(fields: [walletId], references: [id])
}

//////////////////////////////////////////////////////
// INVOICE / RECEIPT
//////////////////////////////////////////////////////

model Invoice {
  id           String   @id
  buildingName String
  fromWId      String
  toWId        String
  timestamp    DateTime
  kWH          Float?
  tokenAmount  Float?
  status String // paid, late, cancelled
  month        Int
  year         Int
  dailyAvg     Float?
  peakDate     DateTime?
  peakkWH      Float?

  receipt Receipt?
}

model Receipt {
  id         String   @id
  invoiceId  String @unique
  timestamp  DateTime
  walletTxId String

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

//////////////////////////////////////////////////////
// ENERGY MARKET
//////////////////////////////////////////////////////

model EnergyOffer {
  id             Int      @id @default(autoincrement())
  sellerWalletId String
  buyerWalletId  String?
  kWH            Float
  kWHSold        Float  @default(0)
  ratePerkWH     Float
  totalPrice     Float
  status         EnergyOfferStatus @default(AVAILABLE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sellerWalletId])
  @@index([status])
}

//////////////////////////////////////////////////////
// LOG / NOTIFICATION
//////////////////////////////////////////////////////

model ActivityLog {
  id           Int      @id @default(autoincrement())
  email        String
  activitytype String
  detail       Json
  createdAt    DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  email     String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// BATTERY / BLOCKCHAIN
//////////////////////////////////////////////////////

model Battery {
  snid                String   @unique
  capacitykWH       Float
  currentkWH        Float  @default(0)
  currentPercentage Float  @default(0)
  buildingId        Int
  ownerId           String   @db.Uuid
  createdAt         DateTime @default(now())
}

model BlockTransaction {
  id         String   @id @default(uuid())
  receiptId  String
  txHash     String?  @unique
  appTxId    String?
  payloadHash String?
  status     String?
  chainId    Int?
  explorerUrl String?
  verificationMethod String?
  contractAddress String?
  height     Float?
  txAmount   Float?
  blockHash  String?
  parentHash String?
  validator  String?
  gasUsed    Float?
  txFee      Float?
  blockSize  Float?
  timestamp  DateTime?
  createdAt  DateTime @default(now())

  @@index([appTxId])
  @@index([status])
}

model Transaction {
  txid        String      @id
  timestamp   DateTime    @default(now())
  buildingName String?
  snid        String?
  walletId    String
  type        String
  tokenAmount Float
  status      TxStatus    @default(CONFIRMED)
  verificationStatus String?
  verificationMethod String?
  chainId     Int?
  verificationPayload String?
  payloadHash String?
  txHash      String?
  explorerUrl String?
  publisherAddress String?
  contractAddress String?
  blockNumber Int?
  gasUsed     String?
  effectiveGasPrice String?
  verifiedAt  DateTime?

  wallet      Wallet      @relation(fields: [walletId], references: [id])
  building    Building?   @relation(fields: [buildingName], references: [name])

  @@index([walletId])
  @@index([buildingName])
  @@index([timestamp])
  @@index([verificationStatus])
  @@index([txHash])
}


