FROM node:20-bookworm-slim AS build

WORKDIR /app

ARG REACT_APP_MOCKUPMODE=false
ARG REACT_APP_APPAPI=http://localhost:8000/api
ARG REACT_APP_API=http://localhost:8000/api/
ARG REACT_APP_API_BASE=http://localhost:8000/api
ARG REACT_APP_APIURL=http://localhost:8000/api/users
ARG REACT_APP_DATAAPI=
ARG REACT_APP_MONGOAPI=
ARG REACT_APP_IOCCMDAPI=
ARG REACT_APP_FOCUSAPI=
ARG REACT_APP_SPHINXAPI=
ARG REACT_APP_PARKINGAPI=
ARG REACT_APP_PARKINGURL=

ENV REACT_APP_MOCKUPMODE=$REACT_APP_MOCKUPMODE
ENV REACT_APP_APPAPI=$REACT_APP_APPAPI
ENV REACT_APP_API=$REACT_APP_API
ENV REACT_APP_API_BASE=$REACT_APP_API_BASE
ENV REACT_APP_APIURL=$REACT_APP_APIURL
ENV REACT_APP_DATAAPI=$REACT_APP_DATAAPI
ENV REACT_APP_MONGOAPI=$REACT_APP_MONGOAPI
ENV REACT_APP_IOCCMDAPI=$REACT_APP_IOCCMDAPI
ENV REACT_APP_FOCUSAPI=$REACT_APP_FOCUSAPI
ENV REACT_APP_SPHINXAPI=$REACT_APP_SPHINXAPI
ENV REACT_APP_PARKINGAPI=$REACT_APP_PARKINGAPI
ENV REACT_APP_PARKINGURL=$REACT_APP_PARKINGURL
ENV GENERATE_SOURCEMAP=false
ENV CI=false
ENV NODE_OPTIONS=--max-old-space-size=4096

COPY package*.json ./
RUN npm install --include=dev --legacy-peer-deps --no-audit --no-fund

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80
