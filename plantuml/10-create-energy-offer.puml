@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam sequence {
  ArrowColor Black
  LifeLineBorderColor Black
  LifeLineBackgroundColor White
  ParticipantBorderColor Black
  ParticipantBackgroundColor White
  ActorBorderColor Black
  ActorBackgroundColor White
  ParticipantFontColor Black
  ActorFontColor Black
}

actor "User" as User
participant "Frontend" as UI
participant "Backend API\nPOST /api/offers" as API
participant "Database\nTable: EnergyOffer" as DB
User->UI: Enter energy offer information
UI->API: Submit energy offer
API->DB: Store energy offer
DB-->API: Offer created successfully
API-->UI: Return offer creation result
UI-->User: Display the created energy offer

@enduml
